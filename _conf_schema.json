{
  "moe_sekai_token": {
    "description": "Your moe-sekai API token",
    "type": "string",
    "obvious_hint": true
  },
  "api_base": {
    "description": "API base URL",
    "type": "string",
    "default": "https://seka-api.exmeaning.com"
  },
  "masterdata_dir": {
    "description": "Path to masterdata directory",
    "type": "string",
    "default": "./masterdata"
  },
  "musicmetas_path": {
    "description": "Path to musicmetas.json",
    "type": "string",
    "default": "./musicmetas.json"
  },
  "default_algorithm": {
    "description": "Default algorithm",
    "type": "string",
    "options": ["ga", "dfs"],
    "default": "ga"
  },
  "default_target": {
    "description": "Default target",
    "type": "string",
    "options": ["score", "power", "skill", "bonus"],
    "default": "score"
  },
  "show_top_decks": {
    "description": "Number of top decks to show",
    "type": "int",
    "default": 3
  }
}
